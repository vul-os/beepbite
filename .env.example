# ==== Vite / Frontend ====
# Loaded by Vite; only VITE_* vars are exposed to the browser.
VITE_API_URL=http://localhost:8080

# ==== Go backend ====
APP_ENV=local
PORT=8080

# Postgres (local docker-compose or local postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beepbite?sslmode=disable

# Auth — email+password and staff PIN. No third-party identity provider.
JWT_SECRET=change-me-32-bytes-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# CORS — comma-separated
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 32-byte key that encrypts small secrets at rest (TOTP seeds, BYO email
# provider credentials). Generate with: openssl rand -hex 32
# Hex, base64 or raw 32 bytes are all accepted. Back it up: losing it means
# losing access to everything it encrypted.
# Override per purpose with TOTP_KEY_ENCRYPTION_SECRET / EMAIL_KEY_ENCRYPTION_SECRET.
APP_KEY_ENCRYPTION_SECRET=

# ==== Optional integrations ====
# Everything below is optional. BeepBite runs without any of it.

# WhatsApp ordering chatbot — uses YOUR OWN Meta credentials.
# BeepBite never holds them and there is no shared account.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Transactional email. SMTP is the default and is the only transport you can
# point at your own server without signing up to anyone.
# Set EMAIL_PROVIDER_DEFAULT to smtp | sendgrid | mailgun | ses.
EMAIL_PROVIDER_DEFAULT=smtp
EMAIL_FROM_DEFAULT=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Address autocomplete + geocoding for delivery.
# Without it the chatbot asks customers to share a pin instead of typing.
MAPBOX_TOKEN=

# AI floor-plan generator and owner assistant (Google Gemini).
GEMINI_API_KEY=

# NOTE: there are no payment-gateway keys. BeepBite records tenders — cash,
# your own card machine, bank transfer, voucher — and never processes a card.
