# ==== Vite / Frontend ====
# Loaded by Vite; only VITE_* vars are exposed to the browser.
VITE_API_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=

# ==== Go backend ====
APP_ENV=local
PORT=8080

# Postgres (local docker-compose or local postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/beepbite?sslmode=disable

# Auth
JWT_SECRET=change-me-32-bytes-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# CORS — comma-separated
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Integrations (optional during local dev)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# 32-byte key that encrypts per-location BYO payment gateway secrets at rest.
# Generate with: openssl rand -hex 32  (hex, base64, or raw 32 bytes accepted)
# NEVER share across environments; losing this key means losing access to all
# stored Paystack/Stripe credentials for every merchant.
PAYMENT_KEY_ENCRYPTION_SECRET=

# Sandbox credentials used by `go run ./cmd/tests --payment-gateways`.
# Paystack: https://dashboard.paystack.com/#/settings/developers (test keys)
# Stripe:   https://dashboard.stripe.com/test/apikeys
PAYSTACK_TEST_SECRET_KEY=
PAYSTACK_TEST_PUBLIC_KEY=
PAYSTACK_TEST_WEBHOOK_SECRET=
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_PUBLIC_KEY=
STRIPE_TEST_WEBHOOK_SECRET=

RESEND_API_KEY=
RESEND_FROM=noreply@beepbite.local

MAPBOX_TOKEN=
OPENAI_API_KEY=
